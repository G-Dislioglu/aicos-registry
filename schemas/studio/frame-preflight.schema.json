{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Frame Preflight",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "preflight_id",
    "subject_ref",
    "task_frame_summary",
    "assumed_goal",
    "explicit_constraints",
    "latent_frame_risks",
    "missing_but_decisive_questions",
    "frame_risk_band",
    "frame_risk_signals",
    "decomposition_readiness",
    "recommended_next_move",
    "proposal_only",
    "shadow_only",
    "non_authoritative"
  ],
  "properties": {
    "artifact_type": { "const": "frame_preflight" },
    "preflight_id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "task_frame_summary": { "type": "string", "minLength": 1 },
    "assumed_goal": { "type": "string", "minLength": 1 },
    "explicit_constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "latent_frame_risks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_but_decisive_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "frame_risk_band": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "frame_risk_signals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "decomposition_readiness": {
      "type": "string",
      "enum": ["ready", "caution", "blocked"]
    },
    "recommended_next_move": {
      "type": "string",
      "enum": ["proceed", "challenge", "narrow", "stop"]
    },
    "notes": { "type": "string", "minLength": 1 },
    "proposal_only": { "const": true },
    "shadow_only": { "const": true },
    "non_authoritative": { "const": true }
  }
}
