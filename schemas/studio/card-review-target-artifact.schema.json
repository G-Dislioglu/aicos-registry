{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Studio Card Review Target Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "review_target_type",
    "topic",
    "proposal_type",
    "target_scope",
    "evidence_status",
    "challenge_status",
    "open_conflicts",
    "review_reason",
    "required_gate_state",
    "next_review_target",
    "promotion_state"
  ],
  "properties": {
    "artifact_type": {
      "const": "card_review_target_artifact"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "review_target_type": {
      "type": "string",
      "enum": [
        "existing_card_boundary",
        "proposed_card_boundary",
        "review_priority_nomination"
      ]
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "proposal_type": {
      "type": "string",
      "enum": [
        "idea_probe",
        "card_review",
        "review_target_candidate",
        "registry_candidate_hint",
        "situation_analysis",
        "design_direction",
        "contradiction_packet",
        "challenge_dossier_seed"
      ]
    },
    "target_scope": {
      "type": "string",
      "minLength": 1
    },
    "evidence_status": {
      "type": "string",
      "enum": [
        "conversation_only",
        "cross_reference_supported",
        "example_supported",
        "needs_evidence"
      ]
    },
    "challenge_status": {
      "type": "string",
      "enum": [
        "unchallenged",
        "challenge_in_progress",
        "challenged_with_open_conflicts",
        "challenge_passed_for_proposal_use"
      ]
    },
    "open_conflicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_reason": {
      "type": "string",
      "minLength": 1
    },
    "required_gate_state": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "user_gate",
          "evidence_gate",
          "conflict_visibility_gate",
          "proposal_only_gate",
          "no_truth_mutation_gate",
          "no_runtime_write_gate",
          "handoff_quality_gate",
          "card_review_target_gate"
        ]
      }
    },
    "next_review_target": {
      "type": "string",
      "enum": [
        "manual_design_followup",
        "request_human_decision",
        "human_registry_review"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "proposal_only",
        "not_promoted"
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "user_gate_decision": {
      "type": "string",
      "minLength": 1
    },
    "review_notes": {
      "type": "string",
      "minLength": 1
    },
    "distillator_notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
