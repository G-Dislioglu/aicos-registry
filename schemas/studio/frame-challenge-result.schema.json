{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Frame Challenge Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "result_id",
    "subject_ref",
    "input_preflight_ref",
    "passes_run",
    "challenge_findings",
    "challenge_outcome",
    "frame_risk_band_after_challenge",
    "residual_risks",
    "recommended_next_move",
    "shadow_only",
    "non_authoritative"
  ],
  "properties": {
    "artifact_type": { "const": "frame_challenge_result" },
    "result_id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "input_preflight_ref": { "type": "string", "minLength": 1 },
    "passes_run": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["constraint_skeptic", "counterframe_probe", "signal_gap_probe"]
      }
    },
    "challenge_findings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "challenge_outcome": {
      "type": "string",
      "enum": ["confirmed", "reframed", "narrowed", "blocked"]
    },
    "frame_risk_band_after_challenge": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "residual_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_next_move": {
      "type": "string",
      "enum": ["proceed", "proceed_with_caution", "revise_frame", "stop"]
    },
    "notes": { "type": "string", "minLength": 1 },
    "shadow_only": { "const": true },
    "non_authoritative": { "const": true }
  }
}
