{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Studio Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "bundle_id",
    "bundle_type",
    "included_artifacts",
    "source_packet_ref",
    "review_refs",
    "gate_report_refs",
    "consistency_status",
    "intended_next_step",
    "proposal_only",
    "no_truth_mutation",
    "no_runtime_write"
  ],
  "properties": {
    "artifact_type": {
      "const": "studio_bundle_manifest"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "bundle_type": {
      "type": "string",
      "enum": [
        "review_package",
        "handoff_package",
        "reference_package",
        "mixed_review_package"
      ]
    },
    "included_artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_type",
          "ref"
        ],
        "properties": {
          "artifact_type": {
            "type": "string",
            "enum": [
              "studio_intake_packet",
              "proposal_artifact",
              "handoff_artifact",
              "reference_artifact",
              "card_review_target_artifact",
              "review_record",
              "gate_report"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_packet_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "gate_report_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "consistency_status": {
      "type": "string",
      "enum": [
        "consistent",
        "needs_review",
        "incomplete",
        "conflict_present"
      ]
    },
    "intended_next_step": {
      "type": "string",
      "enum": [
        "retain_in_review_layer",
        "manual_design_followup",
        "request_human_decision",
        "human_registry_review",
        "archive_only"
      ]
    },
    "proposal_only": {
      "const": true
    },
    "no_truth_mutation": {
      "const": true
    },
    "no_runtime_write": {
      "const": true
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "bundle_summary": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
