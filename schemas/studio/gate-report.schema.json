{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Studio Gate Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "gate_report_id",
    "subject_artifact_type",
    "subject_ref",
    "topic",
    "gate_name",
    "gate_outcome",
    "gate_summary",
    "decision_codes",
    "approval_requirement",
    "record_scope"
  ],
  "properties": {
    "artifact_type": {
      "const": "gate_report"
    },
    "gate_report_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "minLength": 1
    },
    "subject_artifact_type": {
      "type": "string",
      "enum": [
        "studio_intake_packet",
        "proposal_artifact",
        "handoff_artifact",
        "reference_artifact",
        "card_review_target_artifact"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "gate_name": {
      "type": "string",
      "enum": [
        "intake_completeness_gate",
        "evidence_gate",
        "conflict_visibility_gate",
        "proposal_only_gate",
        "no_truth_mutation_gate",
        "no_runtime_write_gate",
        "handoff_quality_gate",
        "card_review_target_gate"
      ]
    },
    "gate_outcome": {
      "type": "string",
      "enum": [
        "pass",
        "soft_fail",
        "hard_stop"
      ]
    },
    "gate_summary": {
      "type": "string",
      "minLength": 1
    },
    "decision_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "insufficient_evidence",
          "unresolved_conflict",
          "proposal_only_keep",
          "handoff_ready",
          "reference_draft_only",
          "registry_review_nomination_only",
          "runtime_forbidden",
          "truth_mutation_forbidden",
          "user_gate_required",
          "archive_preferred",
          "split_required"
        ]
      }
    },
    "approval_requirement": {
      "type": "string",
      "enum": [
        "not_required",
        "required_before_forward",
        "cannot_override_failure"
      ]
    },
    "record_scope": {
      "const": "review_layer_only"
    },
    "observed_issues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
