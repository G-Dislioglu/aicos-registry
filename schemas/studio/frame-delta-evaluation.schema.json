{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Frame Delta Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "scenario_id",
    "subject_ref",
    "baseline_summary",
    "delta_summary",
    "comparison_axes",
    "overall_result",
    "integration_signal",
    "shadow_only",
    "non_authoritative"
  ],
  "properties": {
    "artifact_type": { "const": "frame_delta_evaluation" },
    "scenario_id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "baseline_summary": { "type": "string", "minLength": 1 },
    "delta_summary": { "type": "string", "minLength": 1 },
    "comparison_axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["axis", "winner", "reason"],
        "properties": {
          "axis": {
            "type": "string",
            "enum": ["misframing_detection", "constraint_fidelity", "premature_closure_resistance", "signal_gap_awareness", "actionability_after_challenge"]
          },
          "winner": {
            "type": "string",
            "enum": ["baseline", "delta", "tie"]
          },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "overall_result": {
      "type": "string",
      "enum": ["baseline_better", "delta_better", "mixed"]
    },
    "integration_signal": {
      "type": "string",
      "enum": ["none", "promising", "strong"]
    },
    "delta_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preflight_ref": { "type": "string", "minLength": 1 },
        "challenge_result_ref": { "type": "string", "minLength": 1 }
      }
    },
    "shadow_only": { "const": true },
    "non_authoritative": { "const": true }
  }
}
