{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Studio Review Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "review_record_id",
    "subject_artifact_type",
    "subject_ref",
    "topic",
    "lifecycle_state",
    "decision_type",
    "decision_codes",
    "review_summary",
    "user_gate_status",
    "resulting_next_posture",
    "record_scope"
  ],
  "properties": {
    "artifact_type": {
      "const": "review_record"
    },
    "review_record_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "minLength": 1
    },
    "subject_artifact_type": {
      "type": "string",
      "enum": [
        "studio_intake_packet",
        "proposal_artifact",
        "handoff_artifact",
        "reference_artifact",
        "card_review_target_artifact"
      ]
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "captured",
        "normalized",
        "challenged",
        "gated",
        "forwarded",
        "held",
        "split",
        "archived",
        "discarded"
      ]
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "forward",
        "hold",
        "split",
        "downgrade",
        "archive",
        "discard"
      ]
    },
    "decision_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "insufficient_evidence",
          "unresolved_conflict",
          "proposal_only_keep",
          "handoff_ready",
          "reference_draft_only",
          "registry_review_nomination_only",
          "runtime_forbidden",
          "truth_mutation_forbidden",
          "user_gate_required",
          "archive_preferred",
          "split_required"
        ]
      }
    },
    "review_summary": {
      "type": "string",
      "minLength": 1
    },
    "user_gate_status": {
      "type": "string",
      "enum": [
        "not_required",
        "required_not_yet_granted",
        "required_and_granted",
        "not_applicable"
      ]
    },
    "resulting_next_posture": {
      "type": "string",
      "enum": [
        "retain_in_review_layer",
        "reference_only",
        "manual_design_followup",
        "request_human_decision",
        "human_registry_review",
        "archive_only",
        "discarded"
      ]
    },
    "record_scope": {
      "const": "review_layer_only"
    },
    "gate_report_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_conflicts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
