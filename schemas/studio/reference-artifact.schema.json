{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Studio Reference Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "reference_scope",
    "topic",
    "artifact_source",
    "summary",
    "evidence_status",
    "open_conflicts",
    "proposal_status"
  ],
  "properties": {
    "artifact_type": {
      "const": "reference_artifact"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "reference_scope": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "artifact_source": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_status": {
      "type": "string",
      "enum": [
        "conversation_only",
        "cross_reference_supported",
        "example_supported",
        "needs_evidence"
      ]
    },
    "open_conflicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "proposal_status": {
      "type": "string",
      "enum": [
        "reference_only",
        "proposal_only"
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "comparison_notes": {
      "type": "string",
      "minLength": 1
    },
    "reader_notes": {
      "type": "string",
      "minLength": 1
    },
    "user_gate_decision": {
      "type": "string",
      "minLength": 1
    }
  }
}
