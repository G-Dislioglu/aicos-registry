{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Studio Dossier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "dossier_id",
    "title",
    "topic",
    "dossier_scope",
    "included_artifacts",
    "source_packet_ref",
    "source_packet_summary",
    "included_proposal_refs",
    "review_refs",
    "gate_report_refs",
    "bundle_context_summary",
    "open_conflicts",
    "gate_outcomes",
    "recommended_human_next_step",
    "forbidden_automated_next_steps",
    "proposal_only",
    "no_truth_mutation",
    "no_runtime_write"
  ],
  "properties": {
    "artifact_type": {
      "const": "studio_dossier"
    },
    "dossier_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "dossier_scope": {
      "type": "string",
      "enum": [
        "local_human_review_only"
      ]
    },
    "included_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_type",
          "ref"
        ],
        "properties": {
          "artifact_type": {
            "type": "string",
            "enum": [
              "studio_intake_packet",
              "proposal_artifact",
              "handoff_artifact",
              "reference_artifact",
              "card_review_target_artifact",
              "review_record",
              "gate_report"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_packet_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_packet_summary": {
      "type": "string",
      "minLength": 1
    },
    "included_proposal_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gate_report_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "bundle_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "bundle_context_summary": {
      "type": "string",
      "minLength": 1
    },
    "open_conflicts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gate_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_report_id",
          "gate_name",
          "gate_outcome",
          "subject_ref",
          "approval_requirement"
        ],
        "properties": {
          "gate_report_id": {
            "type": "string",
            "minLength": 1
          },
          "gate_name": {
            "type": "string",
            "enum": [
              "intake_completeness_gate",
              "evidence_gate",
              "conflict_visibility_gate",
              "proposal_only_gate",
              "no_truth_mutation_gate",
              "no_runtime_write_gate",
              "handoff_quality_gate",
              "card_review_target_gate"
            ]
          },
          "gate_outcome": {
            "type": "string",
            "enum": [
              "pass",
              "soft_fail",
              "hard_stop"
            ]
          },
          "subject_ref": {
            "type": "string",
            "minLength": 1
          },
          "approval_requirement": {
            "type": "string",
            "enum": [
              "not_required",
              "required_before_forward",
              "cannot_override_failure"
            ]
          }
        }
      }
    },
    "recommended_human_next_step": {
      "type": "string",
      "enum": [
        "retain_in_review_layer",
        "manual_design_followup",
        "request_human_decision",
        "human_registry_review",
        "archive_only"
      ]
    },
    "forbidden_automated_next_steps": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "runtime_review_object_creation",
          "truth_mutation",
          "card_write",
          "index_write",
          "alias_write",
          "auto_forwarding",
          "provider_execution"
        ]
      }
    },
    "proposal_only": {
      "type": "boolean",
      "const": true
    },
    "no_truth_mutation": {
      "type": "boolean",
      "const": true
    },
    "no_runtime_write": {
      "type": "boolean",
      "const": true
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
