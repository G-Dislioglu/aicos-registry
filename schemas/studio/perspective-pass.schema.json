{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AICOS Perspective Pass",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "pass_id",
    "trigger_conditions",
    "required_questions",
    "allowed_outputs",
    "forbidden_outputs",
    "failure_modes",
    "shadow_only",
    "evaluation_only"
  ],
  "properties": {
    "artifact_type": { "const": "perspective_pass" },
    "pass_id": {
      "type": "string",
      "enum": ["constraint_skeptic", "counterframe_probe", "signal_gap_probe"]
    },
    "trigger_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_questions": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "failure_modes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "shadow_only": { "const": true },
    "evaluation_only": { "const": true }
  }
}
